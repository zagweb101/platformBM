TAMARA_PUBLIC_KEY=""

# Tabby — https://tabby.ai (BNPL — KSA)
TABBY_SECRET_KEY="sk_test_..."
TABBY_PUBLIC_KEY="pk_test_..."
TABBY_MERCHANT_CODE="your-merchant-code"
TABBY_API_URL="https://api.tabby.sa"
# Optional: auth header value registered with Tabby webhooks
TABBY_WEBHOOK_AUTH_HEADER="your-webhook-secret"

# Webhook URLs to register in partner portals:
# Tamara: {NEXTAUTH_URL}/api/webhooks/tamara
# Tabby:  {NEXTAUTH_URL}/api/webhooks/tabby

# Contact form — admin inbox for new messages
CONTACT_ADMIN_EMAIL="info@baytalmosawer.com"

# Cloudflare Stream — signed video embeds
# https://developers.cloudflare.com/stream/viewing-videos/securing-your-stream/
CLOUDFLARE_STREAM_CUSTOMER_CODE="your-customer-subdomain"
CLOUDFLARE_STREAM_KEY_ID="your-signing-key-id"
CLOUDFLARE_STREAM_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Vimeo — signed playback (optional; embed fallback without token)
VIMEO_ACCESS_TOKEN="your-vimeo-access-token"

# Dev only: allow direct MP4 URLs in production player (NOT recommended)
# ALLOW_DIRECT_VIDEO_URLS="true"
